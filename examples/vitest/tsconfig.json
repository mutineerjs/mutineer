{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "build",
    "rootDir": "."
  },
  "include": [
    "mutineer.config.ts",
    "vitest.config.ts",
    "src/**/*",
    "__tests__/**/*"
  ]
}
