{
  "name": "@mutineerjs/mutineer",
  "version": "v0.2.4",
  "type": "module",
  "private": false,
  "bin": {
    "mutineer": "./dist/bin/mutineer.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "lint": "eslint --config ./eslint.config.cjs --ext .ts,.js src/",
    "mutate": "MUTINEER_DEBUG=0 tsx src/bin/mutineer.ts --config mutineer.config.ts"
  },
  "dependencies": {
    "@babel/parser": "^7.28.4",
    "@babel/traverse": "^7.28.4",
    "@babel/types": "^7.28.4",
    "chalk": "^5.6.2",
    "fast-glob": "^3.3.3",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "magic-string": "^0.30.9",
    "react": "^18.3.1",
    "tsx": "^4.20.6"
  },
  "peerDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.15",
    "@vue/compiler-sfc": ">=3.4.0",
    "esbuild": "^0.25.10",
    "vite": "^6.3.6",
    "vitest": "^4.0.15"
  },
  "peerDependenciesMeta": {
    "@vitejs/plugin-vue": { "optional": true },
    "@vitest/coverage-v8": { "optional": true },
    "@vue/compiler-sfc": { "optional": true },
    "vitest": { "optional": true },
    "vite": { "optional": true }
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "jsdom": "^27.0.0",
    "typescript": "^5.5.4",
    "vite": "^6.3.6",
    "vitest": "^4.0.15",
    "vue": "^3.5.12"
  }
}
