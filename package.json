{
  "name": "@mutineerjs/mutineer",
  "version": "0.7.0",
  "description": "A fast, targeted mutation testing framework for JavaScript and TypeScript",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "Billy Jones",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mutineerjs/mutineer.git"
  },
  "bugs": {
    "url": "https://github.com/mutineerjs/mutineer/issues"
  },
  "homepage": "https://github.com/mutineerjs/mutineer#readme",
  "keywords": [
    "mutation-testing",
    "testing",
    "vitest",
    "jest",
    "typescript",
    "javascript",
    "code-quality"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mutineer": "dist/bin/mutineer.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "lint": "eslint --config ./eslint.config.cjs --ext .ts,.js src/",
    "mutate": "MUTINEER_DEBUG=0 tsx src/bin/mutineer.ts --config mutineer.config.ts",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --config ./eslint.config.cjs --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.28.4",
    "chalk": "^5.6.2",
    "fast-glob": "^3.3.3",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "magic-string": "^0.30.9",
    "react": "^19.2.4",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.15",
    "@vue/compiler-sfc": ">=3.4.0",
    "esbuild": "^0.25.10",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "peerDependenciesMeta": {
    "@vitejs/plugin-vue": {
      "optional": true
    },
    "@vitest/coverage-v8": {
      "optional": true
    },
    "@vue/compiler-sfc": {
      "optional": true
    },
    "vitest": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.15",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.5.4",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue": "^3.5.30"
  }
}
